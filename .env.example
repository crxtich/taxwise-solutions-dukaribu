# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Google Drive OAuth (required for client portal Drive integration)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
VITE_GOOGLE_REDIRECT_URI=https://your-domain.com/client-portal/drive/callback

# Note: GOOGLE_CLIENT_SECRET goes in Supabase Edge Function secrets only — never here
